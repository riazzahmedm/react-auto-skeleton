{
  "name": "auto-skeleton-monorepo",
  "private": true,
  "version": "0.0.1",
  "workspaces": [
    "packages/*",
    "examples/*",
    "docs-site"
  ],
  "scripts": {
    "build": "npm run -ws --if-present build",
    "typecheck": "npm run -ws --if-present typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "perf:scan": "node ./scripts/perf-scan.mjs",
    "demo:dev": "npm run --workspace react-demo dev",
    "demo:build": "npm run --workspace react-demo build"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "jsdom": "^29.1.1",
    "lit": "^3.3.3",
    "playwright": "^1.60.0",
    "tsup": "^8.5.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.6",
    "vue": "^3.5.34"
  }
}
