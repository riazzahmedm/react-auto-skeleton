{
  "name": "@auto-skeleton/core",
  "version": "0.0.5",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "keywords": [
    "skeleton",
    "skeleton-loader",
    "dom-scanner",
    "loading",
    "placeholder",
    "zero-config",
    "framework-agnostic",
    "auto-skeleton",
    "getBoundingClientRect",
    "ui"
  ],
  "description": "Framework-agnostic DOM scanner for auto-skeleton. Measures elements with getBoundingClientRect to generate pixel-accurate skeleton bones.",
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
