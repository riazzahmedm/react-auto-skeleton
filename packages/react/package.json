{
  "name": "@auto-skeleton/react",
  "version": "0.0.1",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": ["dist", "dist/styles.css"],
  "sideEffects": ["**/*.css"],
  "scripts": {
    "build": "tsc -p tsconfig.json && cp src/styles.css dist/styles.css",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@auto-skeleton/core": "0.0.1"
  }
}
